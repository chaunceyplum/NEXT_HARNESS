# Copy this file to .env.local (already gitignored) and fill in what you need.
# Restart `npm run dev` after editing — Next.js only reads this at server start.
# Full reference: ENVIRONMENT_VARIABLES.md

# ── MCP connection (required) ──────────────────────────────────────────────
MCP_ENDPOINT_URL=https://your-endpoint.execute-api.us-east-1.amazonaws.com/mcp
# Only if your API Gateway stage enforces auth (a bare 403 Forbidden with no
# JSON body on the "MCP tool catalog" stage is the sign you need one of these):
# MCP_API_KEY=<api-gateway-key>          # sent as x-api-key
# MCP_AUTH_TOKEN=<token>                 # sent as Authorization: Bearer <token>

# ── Chat model: Bedrock (DEFAULT — bedrock:balanced, no Anthropic key needed)
# Requires IAM creds with bedrock:InvokeModel AND model access enabled in the
# AWS Console -> Bedrock -> Model access (separate from IAM, opt-in per model).
# Ships with working default model IDs below; override if your account needs
# different ones (get real model IDs for your account with:
#   aws bedrock list-foundation-models --query 'modelSummaries[].modelId'
# — some accounts need cross-region inference profile IDs instead, prefixed
# like "us.anthropic...").
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...                  # only for temporary/STS credentials
# BEDROCK_CHEAP_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0       # default shown
# BEDROCK_BALANCED_MODEL_ID=anthropic.claude-sonnet-5   # default shown
# BEDROCK_EXPENSIVE_MODEL_ID=anthropic.claude-opus-4-8      # default shown
# DEFAULT_MODEL=bedrock:balanced         # default; or bedrock:cheap | bedrock:expensive

# ── Chat model: Anthropic direct (optional alternative to Bedrock) ────────
# ANTHROPIC_API_KEY=sk-ant-...           # get one at console.anthropic.com
# DEFAULT_MODEL=anthropic:sonnet         # anthropic:haiku | anthropic:sonnet | anthropic:opus

# ── Chat model: OpenAI (optional) ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_CHEAP_MODEL_ID=gpt-4o-mini
# OPENAI_BALANCED_MODEL_ID=gpt-4o

# ── Tool-shortlisting embeddings (optional — falls back to keyword matching
#    automatically if unset or if the call fails, so this is not required to
#    get a working harness) ─────────────────────────────────────────────────
# EMBEDDING_PROVIDER=openai              # or "bedrock" — auto-detected if unset
# EMBEDDING_MODEL_ID=text-embedding-3-small
